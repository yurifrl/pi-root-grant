    "pi-extension",
    "sudo",
    "root-access",
    "coding-agent"
  ],
  "license": "MIT",
  "author": "Oliver Marcusson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OliverMarcusson/pi-root-grant.git"
  },
  "bugs": {
    "url": "https://github.com/OliverMarcusson/pi-root-grant/issues"
  },
  "homepage": "https://github.com/OliverMarcusson/pi-root-grant#readme",
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/root-grant.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
